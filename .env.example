# ── Site gate (Vercel serverless API) ──────────────────────────
SITE_PASSWORD=your-site-password
SESSION_SECRET=change-me-to-a-long-random-string
RESEND_API_KEY=
RESEND_FROM_EMAIL=HPV <support@example.com>
ALERT_EMAIL=you@example.com

# ── Supabase project ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_PAYLOAD_URL=http://localhost:3000

# ── CMS (copy to cms/.env) ─────────────────────────────────────
# Payload uses Supavisor pooler (IPv4) — NOT db.* direct host (IPv6-only on free tier)
# Supabase → Settings → Database → Connection pooling → Session mode (port 5432)
DATABASE_URI=postgresql://postgres.your-project-ref:YOUR_DATABASE_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
PAYLOAD_SECRET=change-me-to-a-long-random-string
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase Storage (optional)
S3_BUCKET=media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
