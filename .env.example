# Public (safe for Vite client bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (Supabase Edge Function secrets — never commit real values)
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=HPV <support@your-domain.com>
# INQUIRY_TO_EMAIL=info@your-domain.com
# APP_PUBLIC_URL=https://your-production-domain.com

# CMS: after migrations, run supabase/seed.sql then supabase/seed_cms.sql
# Storage bucket cms-media is created by 20260714100000_cms_full.sql (public read, admin upload)
